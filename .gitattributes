# Auto detect text files and perform LF normalization
* text=auto

# Java
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Shell scripts (must be LF)
*.sh text eol=lf

# Windows batch (must be CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.class binary
gradlew binary

# Gradle wrapper JAR (use Git LFS or store directly)
gradle/wrapper/gradle-wrapper.jar binary
