# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# Ensure batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Java source files - auto detect
*.java text

# Gradle
*.gradle text
*.gradle.kts text

# Markdown and docs
*.md text
*.txt text

# Config files
*.yml text
*.yaml text
*.json text
*.xml text
*.toml text
*.properties text

# Binaries
*.jar binary
*.png binary
*.ico binary
*.jpg binary
*.svg binary

# Git
.gitattributes text
.gitignore text
