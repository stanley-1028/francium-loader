# EditorConfig for Francium Mod Loader
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{bat,cmd}]
end_of_line = crlf

[*.{md,txt,yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.{xml,html}]
indent_size = 2

[gradlew]
end_of_line = lf
